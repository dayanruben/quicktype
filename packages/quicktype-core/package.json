{
    "name": "quicktype-core",
    "version": "24.0.0",
    "description": "The quicktype engine as a library",
    "license": "Apache-2.0",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/esm/index.d.ts",
                "default": "./dist/esm/index.js"
            },
            "require": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            }
        },
        "./dist/*": "./dist/*",
        "./package.json": "./package.json"
    },
    "repository": "https://github.com/glideapps/quicktype",
    "engines": {
        "node": ">=20.0.0"
    },
    "scripts": {
        "clean": "rm -rf dist node_modules *~",
        "build": "npm run build:cjs && npm run build:esm",
        "build:cjs": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json",
        "build:esm": "node ../../node_modules/typescript/bin/tsc -p tsconfig.esm.json && node script/write-esm-package-json.mjs"
    },
    "dependencies": {
        "@glideapps/ts-necessities": "2.2.3",
        "@types/readable-stream": "4.0.10",
        "@types/urijs": "^1.19.25",
        "browser-or-node": "^3.0.0",
        "collection-utils": "^1.0.1",
        "is-url": "^1.2.4",
        "js-base64": "^3.7.7",
        "lodash": "^4.18.1",
        "pako": "^3.0.1",
        "pluralize": "^8.0.0",
        "readable-stream": "4.5.2",
        "unicode-properties": "^1.4.1",
        "urijs": "^1.19.1",
        "wordwrap": "^1.0.0",
        "yaml": "^2.9.0"
    },
    "devDependencies": {
        "@types/browser-or-node": "^1.3.2",
        "@types/is-url": "^1.2.32",
        "@types/node": "~20.19.0",
        "@types/pluralize": "0.0.30",
        "@types/unicode-properties": "^1.3.0",
        "@types/wordwrap": "^1.0.3",
        "typescript": "~7.0.2"
    },
    "files": [
        "dist"
    ],
    "browser": {
        "fs": false,
        "path": false
    }
}
