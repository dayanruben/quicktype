{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "foo": { "type": "string" },
    "disallowed": false,
    "empty": {
      "type": "array",
      "items": false
    },
    "impossible": {
      "allOf": [false, { "type": "string" }]
    }
  },
  "required": ["foo", "empty"],
  "additionalProperties": false
}
