{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "tuple": {
      "type": "array",
      "prefixItems": [{ "type": "integer" }, { "type": "boolean" }]
    },
    "open": {
      "type": "array",
      "prefixItems": [{ "type": "boolean" }],
      "items": { "type": "integer" }
    }
  },
  "required": ["tuple", "open"]
}
