{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "title": "TextClassificationOutput",
  "type": "array",
  "items": {
    "type": "object",
    "title": "TextClassificationOutputElement",
    "properties": {
      "label": { "type": "string" },
      "score": { "type": "number" }
    },
    "required": ["label", "score"]
  }
